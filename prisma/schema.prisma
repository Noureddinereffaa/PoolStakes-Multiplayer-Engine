generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(uuid())
  username        String    @unique
  email           String?   @unique
  password        String
  balance         Decimal   @default(500.0) @db.Decimal(12, 2)
  walletAddress   String?
  guestExpiresAt  DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  escrowsAsP1   Escrow[]      @relation("Player1")
  escrowsAsP2   Escrow[]      @relation("Player2")
  wonTxs        Transaction[] @relation("Winner")
  lostTxs       Transaction[] @relation("Loser")
  cryptoTxs     CryptoTransaction[]
}

model CryptoTransaction {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  type        String   // "DEPOSIT", "WITHDRAWAL"
  amount      Decimal   @db.Decimal(12, 2)
  currency    String   @default("USDT")
  txHash      String?  @unique
  status      String   @default("PENDING") // "PENDING", "COMPLETED", "FAILED"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Escrow {
  id          String   @id @default(uuid())
  roomName    String
  amountEach  Decimal   @db.Decimal(12, 2)
  status      String   @default("locked") // "locked", "refunded", "payout_completed"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  player1Id   String
  player1     User     @relation("Player1", fields: [player1Id], references: [id])
  
  player2Id   String
  player2     User     @relation("Player2", fields: [player2Id], references: [id])

  transaction Transaction?
}

model Transaction {
  id          String   @id @default(uuid())
  prize       Decimal   @db.Decimal(12, 2)
  commission  Decimal   @db.Decimal(12, 2)
  timestamp   DateTime @default(now())

  escrowId    String   @unique
  escrow      Escrow   @relation(fields: [escrowId], references: [id])

  winnerId    String
  winner      User     @relation("Winner", fields: [winnerId], references: [id])

  loserId     String?
  loser       User?    @relation("Loser", fields: [loserId], references: [id])
}

model RoomSnapshot {
  id          String   @id @default(uuid())
  roomId      String   @unique
  name        String
  stake       Decimal   @db.Decimal(12, 2)
  status      String
  state       String   // JSON-serialized full RoomState (players, balls, turn, etc.)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ApiLog {
  id        String   @id @default(uuid())
  apiName   String
  payload   String
  response  String
  timestamp DateTime @default(now())
}
