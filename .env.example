# ==========================================
# PRODUCTION ENVIRONMENT VARIABLES
# ==========================================
# Copy this file to .env and fill in your values
# Generate JWT_SECRET: openssl rand -base64 32
# Generate DB_PASSWORD: openssl rand -base64 16

# Database - PostgreSQL
# For Docker: postgresql://postgres:DB_PASSWORD@db:5432/pool_game
# For external DB: postgresql://user:pass@host:5432/dbname
DATABASE_URL=postgresql://postgres:your_db_password@db:5432/pool_game

# JWT Secret - CRITICAL: Must be 32+ chars, unique, kept secret
JWT_SECRET=your_super_secure_random_string_at_least_32_characters_long

# App Configuration
NODE_ENV=production
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# Database Password (referenced in docker-compose.yml)
DB_PASSWORD=your_secure_db_password_here

# Optional: External services
# REDIS_URL=redis://redis:6379
# SENTRY_DSN=https://xxx@sentry.io/xxx
# RESEND_API_KEY=re_xxx (for emails)

# Push Notifications (VAPID)
# Generate with: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@8ballpool.com